{
  "name": "school-management-backend",
  "version": "1.0.0",
  "description": "Backend service for school management system",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "init-db": "node src/scripts/initDb.js",
    "setup-db": "node src/scripts/setup-db.js",
    "prisma:generate": "prisma generate --schema=src/models/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=src/models/schema.prisma",
    "prisma:studio": "prisma studio --schema=src/models/schema.prisma",
    "setup": "npm run setup-db && npm run prisma:generate && npm run prisma:migrate && npm run init-db",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.js",
    "format": "prettier --write src/**/*.js"
  },
  "dependencies": {
    "@prisma/client": "^5.6.0",
    "argon2": "^0.31.2",
    "axios": "^1.6.2",
    "bullmq": "^5.0.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.6.5",
    "nodemailer": "^6.9.7",
    "qrcode": "^1.5.3",
    "socket.io": "^4.7.4",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "twilio": "^4.19.3",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.4",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.0",
    "prisma": "^5.6.0",
    "supertest": "^6.3.3"
  }
}
