{
  "name": "school-management-backend",
  "version": "1.0.0",
  "description": "Backend service for school management system",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "init-db": "node src/scripts/initDb.js",
    "setup-db": "node src/scripts/setup-db.js",
    "prisma:generate": "prisma generate --schema=src/models/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=src/models/schema.prisma",
    "prisma:studio": "prisma studio --schema=src/models/schema.prisma",
    "setup": "npm run setup-db && npm run prisma:generate && npm run prisma:migrate && npm run init-db",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.js",
    "format": "prettier --write src/**/*.js",
    "seed": "node prisma/seed.js"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "argon2": "^0.31.2",
    "axios": "^1.6.2",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.63.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.1",
    "express-validator": "^7.3.0",
    "helmet": "^7.2.0",
    "ioredis": "^5.8.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "1.4.5-lts.2",
    "mysql2": "^3.15.3",
    "nodemailer": "^6.10.1",
    "pdfkit": "^0.17.2",
    "qrcode": "^1.5.3",
    "razorpay": "^2.9.6",
    "socket.io": "^4.8.1",
    "stripe": "^19.3.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "twilio": "^4.23.0",
    "uuid": "^13.0.0",
    "winston": "^3.11.0",
    "xlsx": "^0.18.5",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.10.4",
    "@types/uuid": "^11.0.0",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.10",
    "prettier": "^3.1.0",
    "prisma": "^5.6.0",
    "supertest": "^6.3.3",
    "typescript": "^5.9.3"
  }
}
